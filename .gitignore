# Godot 4 — ignore import cache and local export artifacts.
# We DO commit export_presets.cfg (CI needs it to build Android/HTML5).
.godot/
.import/

# Imported translations (auto-generated from CSV)
*.translation

# Mono / C# (we don't use these yet but Godot may emit them)
.mono/
data_*/
mono_crash.*.json

# OS/editor noise
.DS_Store
.directory
*~
.vscode/
.idea/

# Local build + export output (artifacts) — configs stay tracked
build/
export/
dist/
*.apk
*.aab
*.ipa
*.zip
# Android keystores are never committed — signing key lives in $HOME or CI secrets
*.keystore
*.jks
android/debug.keystore
android/release.keystore

# Save files / local test user data
user://
*.save
*.save.bak

# Worktrees (agent teams)
.worktrees/

# Local caches, agent scratch
# NOTE: .remember/ is TRACKED (contains memory docs); only ignore artifacts+temp state
.remember/logs/
.remember/tmp/
.remember/now.md
.remember/*.pid
.tatoeba-cache/
.playwright-mcp/

# Claude local task-batch runtime state (keep directory tracked, ignore volatile files)
.claude/state/task-batch/.last-compaction

# Raw asset drop zone — unzip/import into assets/ intentionally,
# don't commit the archives.
pending/

# Ad-hoc screenshots (never commit screenshots at repo root)
/*.png

# Claude local config (project-scope)
.claude/cache/

# ralph-tui local session/iteration logs (keep config.toml + progress.md tracked)
.ralph-tui/session*.json
.ralph-tui/iterations/
.ralph-tui/reports/
