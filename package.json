{
  "name": "poki-soweli",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "validate-challenges": "node scripts/validate-challenges.mjs",
    "validate-tp": "node scripts/validate-tp.mjs",
    "build-spine": "node scripts/build-spine.mjs",
    "validate": "pnpm validate-challenges && pnpm validate-tp && pnpm author:verify",
    "prebuild": "pnpm validate && pnpm build-spine && pnpm typecheck",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit 2>&1 | grep -v 'node_modules/.*@rpgjs/common/src/rooms/WorldMaps.ts' | tee /dev/stderr | (! grep -qE '^(.+): error')",
    "fetch-dictionary": "node scripts/fetch-dictionary.mjs",
    "fetch-corpus": "node scripts/fetch-tatoeba-corpus.mjs",
    "worktree-gc": "node scripts/worktree-janitor.mjs",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "test:e2e:watch": "vitest --config vitest.config.e2e.ts",
    "author:build": "tsx scripts/map-authoring/cli/build.ts",
    "author:render": "tsx scripts/map-authoring/cli/render.ts",
    "author:validate": "tsx scripts/map-authoring/cli/validate.ts",
    "author:convert-tmx": "tsx scripts/map-authoring/cli/convert-tmx.ts",
    "author:inspect": "tsx scripts/map-authoring/cli/inspect.ts",
    "author:all": "tsx scripts/map-authoring/cli/all.ts",
    "author:verify": "tsx scripts/map-authoring/cli/verify.ts"
  },
  "dependencies": {
    "@canvasengine/presets": "2.0.0-beta.56",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/device": "^8.0.2",
    "@capacitor/preferences": "^6.0.3",
    "@capacitor/screen-orientation": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capacitor-community/sqlite": "^6.0.2",
    "@rpgjs/action-battle": "5.0.0-beta.1",
    "@rpgjs/client": "5.0.0-beta.1",
    "@rpgjs/common": "5.0.0-beta.1",
    "@rpgjs/server": "5.0.0-beta.1",
    "@rpgjs/tiledmap": "5.0.0-beta.1",
    "@rpgjs/ui-css": "5.0.0-beta.1",
    "@rpgjs/vite": "5.0.0-beta.1",
    "@signe/di": "^2.9.0",
    "canvasengine": "2.0.0-beta.56",
    "jeep-sqlite": "^2.7.11",
    "pixi.js": "^8.17.1",
    "sql.js": "^1.12.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@canvasengine/compiler": "2.0.0-beta.56",
    "@types/node": "^25.6.0",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/browser": "^4.1.4",
    "@vitest/browser-playwright": "^4.1.4",
    "fast-xml-parser": "^5.7.1",
    "path-browserify": "^1.0.1",
    "playwright": "^1.59.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@parcel/watcher",
      "sql.js"
    ]
  }
}
