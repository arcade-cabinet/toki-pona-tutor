{
  "name": "rivers-reckoning",
  "private": true,
  "version": "0.32.1",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=10 <11"
  },
  "scripts": {
    "dev": "vite",
    "validate-challenges": "node scripts/validate-challenges.mjs",
    "build-spine": "node scripts/build-spine.mjs",
    "validate": "pnpm validate-challenges && pnpm author:verify",
    "prebuild": "pnpm validate && pnpm build-spine && pnpm typecheck",
    "build": "vite build",
    "postbuild": "node scripts/deploy/prune-deploy-assets.mjs",
    "preview": "vite preview",
    "typecheck": "node scripts/run-typecheck.mjs --all",
    "typecheck:src": "node scripts/run-typecheck.mjs",
    "typecheck:build-time": "node scripts/run-typecheck.mjs --project tsconfig.build-time.json",
    "format:src": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:src:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "workflow:check": "node scripts/workflow-check.mjs",
    "release:smoke-artifacts": "node scripts/deploy/smoke-release-artifacts.mjs",
    "android:build-debug": "node scripts/android-build-debug.mjs",
    "maestro:check": "node scripts/maestro-check.mjs",
    "maestro:android": "maestro test --platform android .maestro/android/debug-apk-smoke.yaml",
    "maestro:ios": "maestro test --platform ios .maestro/ios/pages-safari-smoke.yaml",
    "worktree-gc": "node scripts/worktree-janitor.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --project=unit",
    "test:integration": "vitest run --project=integration",
    "test:coverage": "vitest run --project=unit --coverage",
    "test:e2e": "playwright test --headed",
    "test:e2e:smoke": "playwright test --headed --project=smoke",
    "test:e2e:full": "playwright test --headed --project=full",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "author:build": "tsx scripts/map-authoring/cli/build.ts",
    "author:render": "tsx scripts/map-authoring/cli/render.ts",
    "author:validate": "tsx scripts/map-authoring/cli/validate.ts",
    "author:convert-tmx": "tsx scripts/map-authoring/cli/convert-tmx.ts",
    "author:inspect": "tsx scripts/map-authoring/cli/inspect.ts",
    "author:audit-surfaces": "tsx scripts/map-authoring/cli/surface-audit.ts",
    "art:audit-pending": "node scripts/art-audit/pending-assets.mjs",
    "author:tilesets": "tsx scripts/map-authoring/cli/build-derived-tilesets.ts",
    "author:all": "tsx scripts/map-authoring/cli/all.ts",
    "author:verify": "tsx scripts/map-authoring/cli/verify.ts",
    "android:configure-release-signing": "node scripts/capacitor/configure-release-signing.mjs"
  },
  "dependencies": {
    "@canvasengine/presets": "2.0.0-beta.56",
    "@canvasengine/tiled": "2.0.0-beta.56",
    "@capacitor-community/sqlite": "^8.1.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/device": "^8.0.2",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@rpgjs/action-battle": "5.0.0-beta.1",
    "@rpgjs/client": "5.0.0-beta.1",
    "@rpgjs/common": "5.0.0-beta.1",
    "@rpgjs/server": "5.0.0-beta.1",
    "@rpgjs/tiledmap": "5.0.0-beta.1",
    "@rpgjs/ui-css": "5.0.0-beta.1",
    "@rpgjs/vite": "5.0.0-beta.1",
    "@signe/di": "^2.9.0",
    "canvasengine": "2.0.0-beta.56",
    "jeep-sqlite": "^2.8.0",
    "motion": "^12.38.0",
    "pixi.js": "^8.18.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sql.js": "1.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@canvasengine/compiler": "2.0.0-beta.56",
    "@capacitor/android": "^8.3.1",
    "@playwright/test": "^1.59.1",
    "@rpgjs/testing": "5.0.0-beta.1",
    "@types/node": "^25.6.0",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.4",
    "canvas": "^3.2.3",
    "fast-xml-parser": "^5.7.1",
    "happy-dom": "^20.9.0",
    "image-size": "^2.0.2",
    "path-browserify": "^1.0.1",
    "playwright": "^1.59.1",
    "pngjs": "^7.0.0",
    "prettier": "3.3.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.4",
    "vitest-webgl-canvas-mock": "^1.1.0",
    "yaml": "^2.8.3"
  },
  "pnpm": {
    "overrides": {
      "sql.js": "1.11.0"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "@parcel/watcher",
      "sql.js",
      "canvas"
    ]
  }
}
