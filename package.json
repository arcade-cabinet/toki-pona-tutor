{
  "name": "toki-pona-tutor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "validate-challenges": "node scripts/validate-challenges.mjs",
    "validate-tp": "node scripts/validate-tp.mjs",
    "build-spine": "node scripts/build-spine.mjs",
    "validate": "pnpm validate-challenges && pnpm validate-tp",
    "prebuild": "pnpm validate && pnpm build-spine",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "fetch-dictionary": "node scripts/fetch-dictionary.mjs",
    "fetch-corpus": "node scripts/fetch-tatoeba-corpus.mjs",
    "worktree-gc": "node scripts/worktree-janitor.mjs",
    "test:build-time": "vitest run",
    "test:build-time:watch": "vitest",
    "author:build": "tsx scripts/map-authoring/cli/build.ts",
    "author:render": "tsx scripts/map-authoring/cli/render.ts",
    "author:validate": "tsx scripts/map-authoring/cli/validate.ts",
    "author:convert-tmx": "tsx scripts/map-authoring/cli/convert-tmx.ts",
    "author:inspect": "tsx scripts/map-authoring/cli/inspect.ts",
    "author:all": "tsx scripts/map-authoring/cli/all.ts"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/device": "^8.0.2",
    "@capacitor/screen-orientation": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "canvas-confetti": "^1.9.4",
    "howler": "^2.2.4",
    "koota": "^0.6.6",
    "lucide-react": "^0.468.0",
    "phaser": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "seedrandom": "^3.0.5",
    "solid-js": "^1.9.12",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/canvas-confetti": "^1.9.0",
    "@types/howler": "^2.2.12",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/seedrandom": "^3.0.8",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "canvas": "^3.2.3",
    "fast-xml-parser": "^5.7.1",
    "image-size": "^2.0.2",
    "pngjs": "^7.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^6.0.5",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "canvas",
      "esbuild",
      "@parcel/watcher"
    ]
  }
}
