<DOMContainer width="0" height="0"></DOMContainer>

<script>
    import { computed, effect, mount } from "canvasengine";
    import { riversUiBridge } from "../ui/bridge";

    const { data } = defineProps({
        data: {
            default: () => null
        }
    });

    const view = computed(() => data() || null);

    effect(() => {
        riversUiBridge.update({ defeat: view() });
    });

    mount(() => {
        return () => {
            riversUiBridge.update({ defeat: null });
        };
    });
</script>
