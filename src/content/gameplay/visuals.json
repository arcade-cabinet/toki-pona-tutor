{
  "combat_hp_bar": {
    "width": 58,
    "height": 9,
    "padding": 1,
    "hit_effect_ms": 150,
    "faint_effect_ms": 500,
    "damage_popup_ms": 650,
    "hp_tween_ms": 400,
    "hp_label_template": "HP {current} / {max}",
    "damage_label_template": "-{damage}",
    "tiers": [
      { "class": "hp-healthy", "label": "wawa", "above_ratio": 0.5 },
      { "class": "hp-wounded", "label": "pakala", "above_ratio": 0.2 },
      { "class": "hp-critical", "label": "moli" }
    ],
    "colors": {
      "hp-healthy": "#4a9d5a",
      "hp-wounded": "#d98a3f",
      "hp-critical": "#c85a4a"
    }
  },
  "combat_target_reticle": {
    "padding": 7,
    "min_width": 34,
    "min_height": 32,
    "corner_length": 9,
    "stroke_width": 3,
    "pulse_ms": 900,
    "alpha_min": 0.78,
    "alpha_max": 0.96,
    "primary_color": "#4fd8ff",
    "shadow_color": "#12333d"
  },
  "tap_controls": {
    "blocking_ui_selectors": [
      ".rpg-ui-title-screen",
      ".rpg-ui-dialog",
      ".rpg-ui-save-load",
      "[data-testid=\"pause-overlay\"]"
    ],
    "target_blocking_ui_selectors": [
      ".poki-lead-movebar",
      ".poki-hud-menu-toggle",
      ".poki-hud-hint-glyph"
    ]
  },
  "map_viewport": {
    "default_tile_px": 16,
    "desktop_zoom": 3,
    "mobile_zoom": 3,
    "min_tile_screen_px": 48,
    "max_zoom": 3,
    "poll_ms": 100
  },
  "pixi": {
    "guarded_fx_aliases": ["fx_settings", "fx_spritesheet"]
  },
  "sprite_layouts": {
    "player_three_frame": {
      "frames_width": 3,
      "frames_height": 4,
      "stand_frame_x": 1,
      "stand_rows": { "down": 0, "left": 1, "right": 2, "up": 3 },
      "walk_rows": { "down": 0, "left": 1, "right": 2, "up": 3 },
      "walk_frame_count": 3,
      "walk_speed": 10,
      "attack_speed": 6
    },
    "npc_four_by_thirty_one": {
      "frames_width": 4,
      "frames_height": 31,
      "stand_frame_x": 1,
      "stand_rows": { "down": 1, "left": 4, "right": 7, "up": 10 },
      "walk_rows": { "down": 0, "left": 3, "right": 6, "up": 9 },
      "walk_frame_count": 3,
      "walk_speed": 10
    },
    "combatant_four_by_thirty_one": {
      "frames_width": 4,
      "frames_height": 31,
      "stand_frame_x": 1,
      "stand_rows": { "down": 1, "left": 4, "right": 7, "up": 10 },
      "walk_rows": { "down": 0, "left": 3, "right": 6, "up": 9 },
      "walk_frame_count": 4,
      "walk_speed": 10,
      "attack_speed": 6,
      "skill_speed": 6,
      "defense_speed": 8,
      "hurt_speed": 8
    }
  },
  "player_spritesheets": [
    { "id": "hero", "image": "spritesheets/hero.png", "layout_id": "player_three_frame" },
    { "id": "female", "image": "spritesheets/female.png", "layout_id": "player_three_frame" }
